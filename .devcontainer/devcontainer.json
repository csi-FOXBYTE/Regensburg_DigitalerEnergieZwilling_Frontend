{
    "name": "rg-dez-frontend",
    "dockerComposeFile": [
        "docker-compose.yml"
    ],
    "service": "dev",
    "workspaceFolder": "/workspace",
    "features": {
        "ghcr.io/devcontainers/features/desktop-lite:1": {}
    },
    "customizations": {
        "codespaces": {
            "openFiles": [
                "README.md",
                "CONTRIBUTING.md"
            ]
        },
        "vscode": {
            "extensions": [
                "astro-build.astro-vscode",
                "esbenp.prettier-vscode"
            ]
        }
    }
}