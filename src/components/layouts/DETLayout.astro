---
import BaseLayout from './BaseLayout.astro';
import Header from './header/Header.astro';
import Main from './Main.astro';
import Footer from './Footer.astro';
import ProgressBar from '@/feature/progressBar/ProgressBar';
---

<BaseLayout>
  <Header>
    <ProgressBar client:load />
  </Header>
  <Main>
    <slot />
  </Main>
  <Footer />
</BaseLayout>

<script>
  import { $step } from '@/feature/progressBar/state';

  function update(step: number) {
    document.querySelectorAll<HTMLElement>('[data-step-gate]').forEach((el) => {
      const steps = el.dataset.stepGate!.split(',').map(Number);
      el.style.display = steps.includes(step) ? '' : 'none';
    });
  }

  $step.subscribe(update);
</script>
