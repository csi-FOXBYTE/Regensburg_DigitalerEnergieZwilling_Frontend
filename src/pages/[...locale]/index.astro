---
import MapIsland from "@/feature/map/MapIsland";
import * as Cesium from "cesium";
import type { GetStaticPaths } from "astro";
import DETLayout from "@/components/layouts/DETLayout.astro";
import { buildStaticPaths } from "astro-react-i18next/utils";
import i18n from "i18next";
import LandingPage from "../../feature/landingPage/LandingPage.astro";
import EnergyCalculationPage from "../../components/layouts/EnergyCalculationPage.astro";
import GeneralDataStep from "../../feature/energyCalculation/GeneralDataStep.astro";
import OuterPartsStep from "../../feature/energyCalculation/OuterPartsStep.astro";
import HeatStep from "../../feature/energyCalculation/HeatStep.astro";
import ElectricityStep from "../../feature/energyCalculation/ElectricityStep.astro";
import RenovationStep from "../../feature/energyCalculation/RenovationStep.astro";
import Result from "../../feature/energyCalculation/Result.astro";

export const getStaticPaths = (() => {
  return buildStaticPaths();
}) satisfies GetStaticPaths;

// @ts-expect-error
if (typeof window !== "undefined") window.Cesium = Cesium;
---

<script>
  import { $step, setStep } from "@/feature/progressBar/state";
  document.querySelector("[data-next-step]")?.addEventListener("click", () => {
    setStep($step.get() + 1);
  });
</script>

<DETLayout>
  <LandingPage />
  <MapIsland client:only="react" />
  <GeneralDataStep />
  <OuterPartsStep />
  <HeatStep />
  <ElectricityStep />
  <RenovationStep />
  <Result />
</DETLayout>
