---
import EnergyCalculationPage from '@/components/layouts/EnergyCalculationPage.astro';
import { Typography } from '@/components/ui/typography';
import i18next from 'i18next';
import ButtonBar from '../ButtonBar';
import RenovationStats from '../renovation/RenovationStats';
import EnergyClassDisplay from './EnergyClassDisplay';
---

<EnergyCalculationPage step={7}>
  <Typography variant="h2">
    {i18next.t('energyCalculation:result.title')}
  </Typography>
  <RenovationStats client:load />
  <Typography variant="h3">
    {i18next.t('energyCalculation:result.energyEfficiencyClass')}
  </Typography>
  <EnergyClassDisplay client:load />
  <ButtonBar backTextKey="backFromResults" client:load />
</EnergyCalculationPage>
